PROJECT_NAME           = "Terminal"
PROJECT_BRIEF          = "Modular fintech platform with C++, Rust, pricing, risk, and real-time visualisation components."
PROJECT_NUMBER         = "0.1.0"

OUTPUT_DIRECTORY       = docs/generated/doxygen
CREATE_SUBDIRS         = NO

INPUT                  = README.md \
                         docs/doxygen/mainpage.md \
                         src

RECURSIVE              = YES

FILE_PATTERNS          = *.h \
                         *.hpp \
                         *.hh \
                         *.hxx \
                         *.c \
                         *.cc \
                         *.cpp \
                         *.cxx \
                         *.md

EXCLUDE                = out \
                         build \
                         .git \
                         .github \
                         docs/generated

EXCLUDE_PATTERNS       = */out/* \
                         */build/* \
                         */.git/* \
                         */docs/generated/*

USE_MDFILE_AS_MAINPAGE = docs/doxygen/mainpage.md
MARKDOWN_SUPPORT       = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

HTML_OUTPUT            = html

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS

QUIET                  = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO

CLASS_DIAGRAMS         = YES
HAVE_DOT               = NO

GENERATE_DEPRECATEDLIST = YES