{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-clang-debug",
      "displayName": "Windows Clang Debug + clang-tidy",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_CXX_CLANG_TIDY": "clang-tidy;--config-file=${sourceDir}/.clang-tidy",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/third_party/conan/windows-clang-debug/conan_toolchain.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-windows-clang-debug",
      "displayName": "Build Windows Clang Debug",
      "configurePreset": "windows-clang-debug"
    }
  ],
  "testPresets": [
    {
      "name": "test-windows-clang-debug",
      "displayName": "Test Windows Clang Debug",
      "configurePreset": "windows-clang-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}